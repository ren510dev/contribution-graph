{
  "name": "contribution-graph",
  "version": "1.0.0",
  "repository": "https://github.com/ren510dev/contribution-graph.git",
  "author": "Ren Goto",
  "private": false,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": "24.14.0"
  },
  "scripts": {
    "dev": "rm -rf .wrangler node_modules/.vite && vite build && wrangler dev --var IS_DEV:true",
    "dev:vite": "vite",
    "build": "tsc -p tsconfig.app.json && vite build",
    "preview": "vite build && wrangler dev",
    "deploy": "pnpm build && wrangler deploy"
  },
  "dependencies": {
    "hono": "4.12.14",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260417.1",
    "@playwright/test": "1.59.1",
    "@tailwindcss/vite": "4.2.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "playwright": "1.59.1",
    "prettier": "3.8.3",
    "tailwindcss": "4.2.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite": "6.4.2",
    "wrangler": "4.83.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp"
    ]
  }
}